# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com -> your cluster -> "Connect"
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/eduapp?retryWrites=true&w=majority

# Groq API key (free)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# 4–6 digit PIN your family uses to sign in
PARENT_PIN=1234

# Random 32+ char secret used to sign the auth cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-me-with-a-long-random-hex-string
